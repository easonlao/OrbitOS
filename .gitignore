# Ignore all dot folders by default
.*

# But track .gitkeep for empty directories
!.gitkeep

# Track .gitignore itself
!.gitignore

# Track Claude, Codex, Gemini and Agents configs
!.claude/
.claude/*
!.claude/skills
!.claude/commands/
.claude/settings.local.json

!.gemini/
.gemini/*
!.gemini/skills
!.gemini/commands/
.gemini/settings.json

!.codex/
.codex/*
!.codex/skills

!.agents/

# System files
.DS_Store
.trash/

# Temporary files
*.tmp
*~

# Log files
*.log
