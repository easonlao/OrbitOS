# Ignore all dot folders by default
.*

# But track .gitkeep for empty directories
!.gitkeep

# Track .gitignore and .gitattributes
!.gitignore
!.gitattributes

# Track Claude, Codex, Gemini and Agents configs
!.claude/
.claude/*
!.claude/skills
!.claude/commands/
.claude/settings.local.json

!.gemini/
.gemini/*
!.gemini/skills
!.gemini/commands/
.gemini/settings.json

!.codex/
.codex/*
!.codex/skills

!.agents/

# 用户数据目录（只保留目录结构，不推送实际内容）
00_收件箱/*
!00_收件箱/.gitkeep

10_日记/*
!10_日记/.gitkeep

20_项目/*
!20_项目/.gitkeep

30_研究/*
!30_研究/.gitkeep

40_知识库/*
!40_知识库/.gitkeep

50_资源/*
!50_资源/.gitkeep
!50_资源/Screenshot.png

90_计划/*
!90_计划/.gitkeep

# System files
.DS_Store
.trash/

# Temporary files
*.tmp
*~

# User workspace content
OH-Works/

# Log files
*.log
