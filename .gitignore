
# Local app state
.obsidian/
.obsidianignore
.claude/
.codex/
__pycache__/
*.pyc

# OrbitOS runtime state
.orbitos/cache/
.orbitos/agents/registry.yaml
.orbitos/ingest/batches/*
!.orbitos/ingest/batches/.gitkeep
.orbitos/indexes/*
!.orbitos/indexes/.gitkeep
.orbitos/logs/events/*
!.orbitos/logs/events/.gitkeep
.orbitos/logs/runs/*
!.orbitos/logs/runs/.gitkeep
.orbitos/logs/sessions/*
!.orbitos/logs/sessions/.gitkeep
.orbitos/manifests/*
!.orbitos/manifests/.gitkeep
.orbitos/queues/*
!.orbitos/queues/review/
!.orbitos/queues/review/.gitkeep
.orbitos/state/*
!.orbitos/state/.gitkeep
.orbitos/tmp/
.orbitos/rules/learned/*
!.orbitos/rules/learned/.gitkeep

# User content and local workspace data
01-收件箱/**
!01-收件箱/.gitkeep
02-时间线/*.md
02-时间线/归档/**
!02-时间线/归档/.gitkeep
03-项目/**
!03-项目/
!03-项目/.gitkeep
04-知识/**
!04-知识/
!04-知识/.gitkeep
05-资源/**
!05-资源/.gitkeep
!05-资源/附件/
!05-资源/附件/.gitkeep
06-输出/**
!06-输出/.gitkeep
99-归档/**
!99-归档/.gitkeep

# Local agent profiles
00-系统/agents/*.md
!00-系统/agents/README.md

