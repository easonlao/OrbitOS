# ── Obsidian 个人数据（不 commit）────────────────────────────
# 保留：插件本体（plugins/*/main.js, manifest.json, styles.css）
# 排除：个人配置、缓存、插件用户数据

.obsidian/workspace.json        # 当前打开的文件、面板布局
.obsidian/workspace-mobile.json
.obsidian/hotkeys.json          # 快捷键（个人设置）
.obsidian/graph.json            # 图谱视图设置
.obsidian/starred.json          # 收藏夹

# 插件个人数据（含凭据、对话历史、同步配置）
.obsidian/plugins/remotely-save/
.obsidian/plugins/lingxi/
.obsidian/plugins/claudian/
.obsidian/plugins/*/data.json
.obsidian/plugins/*/data/

# 缓存
.obsidian/cache
.obsidian/.cache

# ── OrbitOS 机器级配置（不 commit）──────────────────────
# Codex 项目级本机配置与 Skill 注册
.codex/
.obsidian/
.claude/
.claudian/
OH-Works/
# 本机 vault 路径配置（可选）
.orbit/config.yaml
# 审计报告（本机生成，不共享）
.orbit/reports/
# 迁移 manifest（本机临时）
.orbit/manifests/
# 处理队列（本机临时）
.orbit/queues/
# 运行时事件日志（含本机路径，不共享）
.orbit/events/

# ── 系统 ─────────────────────────────────────────────────────
.DS_Store
*.swp

# ── 系统 ─────────────────────────────────────────────────────
.DS_Store
*.swp
*.tmp

# ── 日常内容文件（模板 repo 不包含个人数据）────────────────────
# 结构目录保留，内容文件不 commit
01-收件箱/**/*
02-日记/**/*
03-知识/**/*
04-项目/**/*
05-资源/**/*
06-输出/**/*
99-归档/**/*

# 仅保留 WORKSPACE.md 作为框架规范文件进行追踪
!**/WORKSPACE.md
